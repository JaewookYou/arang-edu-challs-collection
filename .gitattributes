# 컨테이너 안에서 실행되는 파일은 반드시 LF (윈도우에서 CRLF 로 체크아웃되면 entrypoint/스크립트가 깨짐)
* text=auto eol=lf

*.sh            text eol=lf
entrypoint.sh   text eol=lf
gen_flags.sh    text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf
*.py            text eol=lf
*.php           text eol=lf
*.jsp           text eol=lf
*.java          text eol=lf
*.sql           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
.env            text eol=lf

# 윈도우 전용 스크립트는 CRLF
*.ps1           text eol=crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf

# 바이너리 (변환 금지)
*.jar           binary
*.gif           binary
*.png           binary
*.jpg           binary
chromedriver    binary
